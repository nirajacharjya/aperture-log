rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /* ---------------- Photos ---------------- */

    match /photos/{photoId} {

      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null
                    && (
                      // Anyone signed in can react (heart/haha/wow/clap/fire counts)
                      request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['reactions'])
                      ||
                      // Only the owner can edit their own photo's text fields
                      (request.auth.uid == resource.data.userId
                       && request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(['title', 'category', 'location', 'story']))
                    );

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;

      match /reactedUsers/{uid} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read: if true;

        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
      }
    }

    /* ---------------- Articles ---------------- */

    match /articles/{articleId} {

      allow read: if true;

      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data)
                       .affectedKeys()
                       .hasOnly(['reactions']);

      match /reactedUsers/{uid} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read: if true;

        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
      }
    }

    /* ---------------- Contact Messages ---------------- */

    match /contactMessages/{messageId} {

      // Anyone can submit a contact message
      allow create: if true;

      // Nobody can read or delete messages from the client
      allow read, update, delete: if false;
    }

    /* ---------------- Stories ---------------- */

    match /stories/{storyId} {

      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null
                    && (
                      // Anyone signed in can react (heart/haha/wow/clap/fire counts)
                      request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['reactions'])
                      ||
                      // Only the owner can edit their own story's text fields
                      (request.auth.uid == resource.data.userId
                       && request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(['title', 'category', 'contentHTML']))
                    );

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;

      match /reactedUsers/{uid} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read: if true;

        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
      }
    }

  }
}